APP_ENV=development
DEPLOYMENT_PROFILE=production_shaped
DATABASE_URL=sqlite:///./odisha_health_hub.db
# Remote PostgreSQL URLs must include sslmode=verify-full&sslrootcert=system.
REQUIRE_POSTGRES=false
PUBLIC_WRITE_ENABLED=false
DEMO_API_TOKEN=change-me-for-local-use
COLLECTOR_API_TOKEN=change-me-for-local-use
APPROVED_PDF_SHA256S=
PUBLIC_API_BASE_URL=
# Hosted schedule only (not read from this application .env): create the admin-only
# GitHub Actions secret COLLECTOR_API_BASE_URL and pair it with COLLECTOR_API_TOKEN.
ALLOWED_ORIGINS=http://localhost:5173
# Live collection is the product, so it is on by default. Set
# LIVE_COLLECTION_ENABLED=false to withhold every outbound request, or
# ENABLE_IN_PROCESS_SCHEDULER=false to keep manual/hosted ticks only.
ENABLE_IN_PROCESS_SCHEDULER=true
LIVE_COLLECTION_ENABLED=true
COLLECTOR_JOBS_PER_TICK=40
COLLECTOR_FETCH_WORKERS=8
# Fixtures are an explicit opt-in for tests and offline demos; live signals are
# the default layer once collection has run.
AUTO_REPLAY_FIXTURES=false
# Optional. The crawler already identifies itself and its project in the
# User-Agent; setting this adds a monitored mailbox on top. Placeholder values
# (example.invalid, "replace-with", "change-me", "unset") are ignored.
CRAWLER_CONTACT=
SOURCE_REGISTRY_PATH=config/sources.yaml
BOUNDARY_PATH=data/boundaries/odisha_districts_census_2011.geojson
FIXTURE_ROOT=tests/fixtures
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
CDSAPI_KEY=
CDS_LICENCE_ACCEPTED=false
CDS_REQUEST_ID=
VITE_API_BASE_URL=http://localhost:8000

# On-device NLP. Leave unset for the normal build: whatever is in models/ is used
# and anything absent reports a typed unavailable state.
#   ODISHA_NLP_MODE=off            disable every model path regardless of disk
#   ODISHA_MODELS_DIR=/path        serve a subset, e.g. translation models only
#   ODISHA_TRANSLATION_RESIDENT=1  keep one translation direction loaded at a time.
#     Loading the second direction while the first is resident peaks near 1.2 GB;
#     evicting first peaks near 0.9 GB. Required to fit a 1 GB container, costs a
#     ~1 s reload when a request flips direction. See DEPLOY_FREE.md.
ODISHA_NLP_MODE=
ODISHA_MODELS_DIR=
ODISHA_TRANSLATION_RESIDENT=
