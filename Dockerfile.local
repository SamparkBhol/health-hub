FROM ghcr.io/astral-sh/uv:0.11.6@sha256:b1e699368d24c57cda93c338a57a8c5a119009ba809305cc8e86986d4a006754 AS uv-binaries

# Build stage: llama-cpp-python has no manylinux wheel and compiles from source, so
# a toolchain is required here. It is deliberately kept out of the runtime image.
FROM python:3.12-slim@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de AS deps

ENV UV_LINK_MODE=copy

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential cmake ninja-build \
    && rm -rf /var/lib/apt/lists/*

COPY --from=uv-binaries /uv /uvx /bin/

WORKDIR /app
COPY pyproject.toml uv.lock ./
# The `nlp` extra carries translation, embeddings and grounded generation. It is
# optional in the package metadata because the wheels are large, but the assistant
# is the product, so the runtime image installs it by default.
#
# Three build profiles, because free hosts differ by an order of magnitude in RAM:
#
#   --extra nlp        (default)  everything: translation, retrieval, generation
#   --extra translate            Odia/Hindi/English answers, no retrieval or LLM.
#                                Skips llama-cpp-python, which is sdist-only and
#                                compiles llama.cpp during install -- the usual
#                                cause of a failed build on a small free host.
#   (empty)                      data and forecast only; English answers.
#
# `packages.nlp` reports typed unavailable states for whatever is absent rather
# than failing, so all three profiles serve. The public deployment uses the full
# `nlp` profile.
ARG UV_SYNC_EXTRAS="--extra nlp"
RUN uv sync --no-dev --no-install-project --frozen ${UV_SYNC_EXTRAS}


FROM python:3.12-slim@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    PATH="/app/.venv/bin:$PATH"

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl poppler-utils tesseract-ocr tesseract-ocr-eng tesseract-ocr-hin tesseract-ocr-ori \
    && rm -rf /var/lib/apt/lists/*

COPY --from=uv-binaries /uv /uvx /bin/

WORKDIR /app
# The already-resolved virtualenv, compiler left behind.
COPY --from=deps /app/.venv /app/.venv
COPY pyproject.toml uv.lock ./

COPY . .
RUN python scripts/doctor.py --runtime \
    && python scripts/make_synthetic.py \
    && groupadd --system app \
    && useradd --system --gid app --home-dir /app --shell /usr/sbin/nologin app \
    && mkdir -p /app/runtime \
    && chown app:app /app/runtime

USER app

EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl --fail http://127.0.0.1:8000/api/v1/readyz || exit 1

CMD ["uvicorn", "services.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--proxy-headers"]
